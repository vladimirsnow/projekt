HOST=0.0.0.0
PORT=3000

# HTTPS (optional)
# SSL_KEY_PATH=/absolute/path/to/key.pem
# SSL_CERT_PATH=/absolute/path/to/cert.pem

# SMTP for real password recovery emails
# Option 1: host/port
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=465
# SMTP_SECURE=true
# SMTP_USER=your_email@gmail.com
# SMTP_PASS=your_app_password

# Option 2: service shortcut
# SMTP_SERVICE=gmail
# SMTP_USER=your_email@gmail.com
# SMTP_PASS=your_app_password

# Optional sender title
# MAIL_FROM=Hexlet Messenger <no-reply@your-domain.com>
